{
  "name": "customelements",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "rm -rf dist .parcel-cache",
    "predev": "pnpm clean",
    "dev": "parcel src/index.html",
    "prebuild": "pnpm clean && pnpm lint && pnpm format",
    "build": "parcel build src/index.html",
    "lint": "biome lint .",
    "format:biome": "biome format --write .",
    "format:prettier": "prettier --write \"**/*.{html,css,json}\"",
    "format": "pnpm format:prettier && pnpm format:biome"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@parcel/config-default": "2.16.4",
    "@parcel/transformer-inline-string": "2.16.4",
    "@parcel/transformer-typescript-tsc": "2.16.4",
    "@parcel/transformer-typescript-types": "2.16.4",
    "baseline-browser-mapping": "^2.10.0",
    "parcel": "2.16.4",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  }
}